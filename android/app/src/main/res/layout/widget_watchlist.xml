<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Watchlist"
            android:textColor="#EAEAEA"
            android:textSize="12sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_popup_sync" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_row_1_ticker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BBCA.JK"
                android:textColor="#F2F2F2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_row_1_decision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="BUY"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:background="@drawable/decision_buy_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_1_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rp 4,120"
                android:textColor="#D7D2C7"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_row_1_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1.24%"
                android:textColor="#6FD08A"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_1_sector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Banking"
                android:textColor="#9C9386"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_row_1_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score 0.742"
                android:textColor="#C7A66A"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_row_1_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="52W: Rp 3,100 - Rp 4,800"
            android:textColor="#9C9386"
            android:textSize="9sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#3C332B" />

    <LinearLayout
        android:id="@+id/widget_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_row_2_ticker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="AAPL"
                android:textColor="#F2F2F2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_row_2_decision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="HOLD"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:background="@drawable/decision_hold_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_2_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$187.24"
                android:textColor="#D7D2C7"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_row_2_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-0.42%"
                android:textColor="#E0705A"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_2_sector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Technology"
                android:textColor="#9C9386"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_row_2_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score 0.612"
                android:textColor="#C7A66A"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_row_2_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="52W: $135.40 - $198.20"
            android:textColor="#9C9386"
            android:textSize="9sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#3C332B" />

    <LinearLayout
        android:id="@+id/widget_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_row_3_ticker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TLKM.JK"
                android:textColor="#F2F2F2"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_row_3_decision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="NO BUY"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:background="@drawable/decision_no_bg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_3_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rp 3,210"
                android:textColor="#D7D2C7"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_row_3_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+0.10%"
                android:textColor="#6FD08A"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_row_3_sector"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Telecom"
                android:textColor="#9C9386"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_row_3_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score 0.431"
                android:textColor="#C7A66A"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_row_3_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="52W: Rp 2,900 - Rp 4,100"
            android:textColor="#9C9386"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
